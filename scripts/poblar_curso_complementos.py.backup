        duration_minutes=60,
        order=11
    )
    Lesson.objects.create(
        module=module,
        title="Práctica: Hipérbola",
        lesson_type=LessonTypeChoices.ASSIGNMENT,
        order=12,
        assignment_instructions="Analiza el comportamiento del costo promedio C(x)=500/x+2. ¿Qué pasa cuando x → ∞?"
    )

    # Semana 15
    Lesson.objects.create(
        module=module,
        title="Semana 15: Caso de estudio - Plan de negocio",
        lesson_type=LessonTypeChoices.ASSIGNMENT,
        order=13,
        assignment_instructions=(
            "Desarrolla un pequeño plan de negocio donde apliques:\n"
            "- Porcentajes (márgenes de ganancia)\n"
            "- Ecuaciones lineales (costos, ingresos)\n"
            "- Matrices (inventarios)\n"
            "- Función lineal (proyección de ventas)\n"
