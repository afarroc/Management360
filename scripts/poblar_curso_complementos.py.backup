    # Semana 16
    Lesson.objects.create(
        module=module,
        title="Semana 16: Examen final",
        lesson_type=LessonTypeChoices.QUIZ,
        duration_minutes=120,
        order=14,
        quiz_questions=[
            {
                "question": "Pregunta de ejemplo final (integradora)",
                "options": ["Opción A", "Opción B", "Opción C", "Opción D"],
                "correct_answer": "Opción A",
                "type": "multiple_choice"
            }
        ]
    )


def _crear_content_blocks(author):
    """Crea algunos bloques de contenido reutilizables."""
    block, created = ContentBlock.objects.get_or_create(
        slug="concepto-porcentaje",
        defaults={
            "title": "Concepto de Porcentaje",
            "description": "Explicación básica de porcentajes para aplicaciones comerciales",
            "content_type": "html",
            "html_content": (
                "<div class='alert alert-info'>"
                "<h4>¿Qué es un porcentaje?</h4>"
                "<p>El porcentaje representa una proporción por cada 100 unidades. "
                "Por ejemplo, 25% significa 25 de cada 100.</p>"
                "<p><strong>Fórmula:</strong> Parte = (Porcentaje/100) × Total</p>"
                "</div>"
            ),
            "author": author,
            "is_public": True
        }
    )
    if created:
        print("✅ Bloque reutilizable 'Concepto de Porcentaje' creado.")


# ----------------------------------------------------------------------
# Punto de entrada
# ----------------------------------------------------------------------
if __name__ == "__main__":
    import argparse
    parser = argparse.ArgumentParser(
        description="Crea la estructura del curso Complementos de Matemática en la app courses."
    )
    parser.add_argument(
        "--tutor",
        help="Username del tutor que será dueño del curso (debe tener CV asociado)."
    )
    args = parser.parse_args()

    try:
        create_course_structure(args.tutor)
    except Exception as e:
        print(f"❌ Error: {e}")
        sys.exit(1)