    Lesson.objects.create(
        module=module,
        title="Práctica: Cuadráticas",
        lesson_type=LessonTypeChoices.ASSIGNMENT,
        order=4,
        assignment_instructions="Resuelve: x² - 5x + 6 = 0 y explica su interpretación en un problema de ingresos."
    )

    # Semana 7
    Lesson.objects.create(
