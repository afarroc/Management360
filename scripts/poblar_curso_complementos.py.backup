        quiz_questions=[
            {
                "question": "Resuelve log₂(x) + log₂(x-2) = 3",
                "options": ["x=4", "x=6", "x=8", "x=10"],
                "correct_answer": "x=4",
                "type": "multiple_choice"
            }
        ]
    )


def _crear_lecciones_unidad3(module):
    """Unidad III: Geometría Analítica y Álgebra Lineal (semanas 9-15)"""
    # Semana 9
    Lesson.objects.create(
        module=module,
        title="Semana 9: Matrices",
        lesson_type=LessonTypeChoices.TEXT,
        content="<h2>Matrices</h2><p>Operaciones básicas y determinantes.</p>",
        duration_minutes=60,
        order=1
    )
    Lesson.objects.create(
        module=module,
        title="Práctica: Matrices",
        lesson_type=LessonTypeChoices.QUIZ,
        order=2,
        quiz_questions=[
            {
                "question": "Dadas A=[[1,2],[3,4]] y B=[[0,1],[1,0]], calcula A+B",
                "options": ["[[1,3],[4,4]]", "[[1,3],[4,4]]", "[[1,3],[4,4]]", "[[1,3],[4,4]]"],
                "correct_answer": "[[1,3],[4,4]]",
                "type": "multiple_choice"
            }
        ]
    )

    # Semana 10
    Lesson.objects.create(
        module=module,
        title="Semana 10: Sistemas de ecuaciones lineales",
        lesson_type=LessonTypeChoices.TEXT,
        content="<h2>Sistemas 2x2 y 3x3. Método de Cramer.</h2>",
        duration_minutes=60,
        order=3
    )
    Lesson.objects.create(
        module=module,
        title="Práctica: Sistemas",
        lesson_type=LessonTypeChoices.ASSIGNMENT,
        order=4,
        assignment_instructions="Resuelve el sistema de producción de sillas y mesas usando matrices."
    )

    # Semana 11
    Lesson.objects.create(
        module=module,
        title="Semana 11: La recta",
        lesson_type=LessonTypeChoices.TEXT,
        content="<h2>Función lineal: pendiente, ecuación punto-pendiente.</h2>",
        duration_minutes=60,
        order=5
    )
    Lesson.objects.create(
        module=module,
        title="Taller PCC",
        lesson_type=LessonTypeChoices.QUIZ,
        order=6,
        quiz_questions=[
            {
                "question": "Pendiente de la recta que pasa por (1,2) y (3,8)",
                "options": ["2", "3", "4", "5"],
                "correct_answer": "3",
                "type": "multiple_choice"
            }
        ]
    )

    # Semana 12
    Lesson.objects.create(
        module=module,
        title="Semana 12: Aplicaciones de la recta",
        lesson_type=LessonTypeChoices.TEXT,
        content="<h2>Depreciación lineal, costo, ingreso.</h2>",
        duration_minutes=60,
        order=7
    )
    Lesson.objects.create(
        module=module,
        title="Evaluación T2",
        lesson_type=LessonTypeChoices.QUIZ,
        duration_minutes=60,
        order=8,
        quiz_questions=[
            {
                "question": "Una máquina cuesta S/50 000 y se deprecia linealmente a S/5 000 en 10 años. ¿Valor tras 4 años?",
                "options": ["S/32 000", "S/30 000", "S/28 000", "S/25 000"],
                "correct_answer": "S/32 000",
                "type": "multiple_choice"
            }
        ]
    )

    # Semana 13
    Lesson.objects.create(
        module=module,
        title="Semana 13: La parábola",
        lesson_type=LessonTypeChoices.TEXT,
        content="<h2>Elementos de la parábola. Aplicación a maximización.</h2>",
