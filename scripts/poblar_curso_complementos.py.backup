        module=module,
        title="Práctica: Ecuaciones lineales",
        lesson_type=LessonTypeChoices.QUIZ,
        order=2,
        quiz_questions=[
            {
                "question": "Resuelve: 3x + 5 = 20",
                "options": ["5", "15", "25", "10"],
                "correct_answer": "5",
                "type": "multiple_choice"
            }
        ]
    )

    # Semana 6
    Lesson.objects.create(
        module=module,
        title="Semana 6: Ecuaciones cuadráticas",
        lesson_type=LessonTypeChoices.TEXT,
        content="<h2>Ecuaciones de segundo grado</h2><p>Fórmula general. Aplicación a ingresos.</p>",
        duration_minutes=60,
        order=3
