class CreditAccount(models.Model):
    """User credit account for transactions"""
    user = models.OneToOneField(User, on_delete=models.CASCADE)
    balance = models.DecimalField(max_digits=10, decimal_places=2, default=Decimal('0.00'))

    def __str__(self):
        return f"{self.user.username} - {self.balance} credits"

    def add_credits(self, amount):
        """Add credits to account"""
        if not isinstance(amount, Decimal):
            amount = Decimal(str(amount))
        self.balance += amount
        self.save()
        logger.info(f"Added {amount} credits to {self.user.username}")

    def subtract_credits(self, amount):
        """Subtract credits from account"""
        if not isinstance(amount, Decimal):
            amount = Decimal(str(amount))
        if amount > self.balance:
            raise ValueError("Insufficient credits")
        self.balance -= amount
        self.save()
        logger.info(f"Subtracted {amount} credits from {self.user.username}")


class Room(models.Model):
