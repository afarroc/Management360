        verbose_name_plural = "GTD Learning Entries"


class GTDProcessingSettings(models.Model):
    """Settings for automated GTD processing"""
    
    # Auto-processing settings
    auto_email_processing = models.BooleanField(default=True, help_text="Automatic email processing")
    auto_call_queue = models.BooleanField(default=True, help_text="Automatic call queue")
    auto_chat_routing = models.BooleanField(default=True, help_text="Automatic chat routing")

    # Performance settings
    processing_interval = models.IntegerField(default=60, help_text="Processing interval in seconds")
    max_concurrent_items = models.IntegerField(default=5, help_text="Maximum concurrent items")

    # Type-specific settings
    email_batch_size = models.IntegerField(default=10, help_text="Email batch size")
    call_queue_timeout = models.IntegerField(default=30, help_text="Call queue timeout in seconds")
    chat_response_timeout = models.IntegerField(default=300, help_text="Chat response timeout in seconds")

    # Agent/bot settings
    enable_bot_cx = models.BooleanField(default=True, help_text="Enable Bot CX")
    enable_bot_atc = models.BooleanField(default=True, help_text="Enable Bot ATC")
    enable_human_agents = models.BooleanField(default=True, help_text="Enable human agents")

    # Priority settings
    auto_priority_assignment = models.BooleanField(default=True, help_text="Automatic priority assignment")
    priority_threshold_high = models.IntegerField(default=80, help_text="High priority threshold")
    priority_threshold_medium = models.IntegerField(default=50, help_text="Medium priority threshold")

    # Metadata
    created_by = models.ForeignKey(User, on_delete=models.CASCADE)
    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)
    is_active = models.BooleanField(default=True, help_text="Active configuration")

    def __str__(self):
        return f"GTD Processing Settings - {self.created_by.username}"

    class Meta:
        verbose_name = "GTD Processing Settings"
        verbose_name_plural = "GTD Processing Settings"
        ordering = ['-updated_at']

    @classmethod
    def get_active_settings(cls):
        """Get current active settings"""
        return cls.objects.filter(is_active=True).first()

    def save(self, *args, **kwargs):
        # Ensure only one active configuration per user
        if self.is_active:
            cls = self.__class__
            cls.objects.filter(created_by=self.created_by, is_active=True).exclude(pk=self.pk).update(is_active=False)
        super().save(*args, **kwargs)


