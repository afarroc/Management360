class GTDClassificationPattern(models.Model):
    """Patterns for automatic GTD classification"""
    GTD_CATEGORIES = [
        ('actionable', 'Actionable'),
        ('non_actionable', 'Non Actionable'),
        ('pending', 'Pending Categorization')
    ]
    
    ACTION_TYPES = [
        ('do', 'Do'),
        ('delegate', 'Delegate'),
        ('defer', 'Defer'),
        ('project', 'Convert to Project'),
        ('delete', 'Delete'),
        ('archive', 'Archive for Reference'),
        ('incubate', 'Incubate (Someday/Maybe)'),
        ('waiting', 'Waiting For')
    ]
    
    PRIORITY_LEVELS = [
        ('high', 'High'),
        ('medium', 'Medium'),
        ('low', 'Low')
    ]
    
    ENERGY_LEVELS = [
        ('low', 'Low Energy'),
        ('medium', 'Medium Energy'),
        ('high', 'High Energy')
    ]
    
    KEYWORD_OPERATORS = [
        ('AND', 'All keywords'),
        ('OR', 'Any keyword'),
        ('NOT', 'None of the keywords')
    ]

    name = models.CharField(max_length=100, help_text="Descriptive pattern name")
    description = models.TextField(help_text="Description of when to apply this pattern")

    # Pattern conditions
    keywords = models.JSONField(help_text="List of keywords that trigger this pattern")
    keywords_operator = models.CharField(max_length=10, choices=KEYWORD_OPERATORS, default='OR')

    # Classification results
    gtd_category = models.CharField(max_length=20, choices=GTD_CATEGORIES)
    action_type = models.CharField(max_length=20, choices=ACTION_TYPES)
    priority = models.CharField(max_length=10, choices=PRIORITY_LEVELS, default='medium')
    energy_required = models.CharField(max_length=20, choices=ENERGY_LEVELS, default='medium')

    # Pattern configuration
    is_active = models.BooleanField(default=True)
    confidence_score = models.IntegerField(default=70, help_text="Confidence level (0-100%)")
    usage_count = models.IntegerField(default=0, help_text="Times this pattern has been used")

    # Metadata
    created_by = models.ForeignKey(User, on_delete=models.CASCADE)
    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)

    def __str__(self):
        return f"{self.name} ({self.gtd_category} -> {self.action_type})"

    class Meta:
        verbose_name = "GTD Classification Pattern"
        verbose_name_plural = "GTD Classification Patterns"


