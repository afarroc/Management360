class TaskDependency(models.Model):
    """Task dependency relationships"""
    DEPENDENCY_TYPES = [
        ('finish_to_start', 'Finish to Start'),
        ('start_to_start', 'Start to Start'),
        ('finish_to_finish', 'Finish to Finish'),
        ('start_to_finish', 'Start to Finish')
    ]
    
    task = models.ForeignKey('Task', on_delete=models.CASCADE, related_name='dependencies')
    depends_on = models.ForeignKey('Task', on_delete=models.CASCADE, related_name='blocking')
    dependency_type = models.CharField(max_length=20, choices=DEPENDENCY_TYPES)
    created_at = models.DateTimeField(auto_now_add=True)

    def __str__(self):
        return f"{self.task.title} depends on {self.depends_on.title}"

    class Meta:
        unique_together = ['task', 'depends_on']


class Task(models.Model):
    """Main task model"""
    title = models.CharField(max_length=200)
    description = models.TextField(null=True, blank=True)
    important = models.BooleanField(default=False)
    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)
    done = models.BooleanField(default=False)
    project = models.ForeignKey('Project', on_delete=models.CASCADE, blank=True, null=True)
    event = models.ForeignKey('Event', on_delete=models.CASCADE, blank=True, null=True)
    task_status = models.ForeignKey(TaskStatus, on_delete=models.CASCADE)
    assigned_to = models.ForeignKey(User, on_delete=models.CASCADE, related_name='managed_tasks')
    host = models.ForeignKey(User, on_delete=models.CASCADE, related_name='hosted_tasks')
    ticket_price = models.DecimalField(default=0, max_digits=6, decimal_places=2)
    tags = models.ManyToManyField(Tag, blank=True)

    processed_inbox_items = GenericRelation(
        'InboxItem',
        related_name='processed_tasks',
        content_type_field='processed_to_content_type',
        object_id_field='processed_to_object_id',
        blank=True
    )

    def change_status(self, new_status_id, user=None):
        """Change task status and create state record"""
        try:
            new_status = TaskStatus.objects.get(id=new_status_id)
            old_status_name = self.task_status.status_name if self.task_status else None

            current_state = self.taskstate_set.filter(end_time__isnull=True).last()
            if current_state:
                current_state.end_time = timezone.now()
                current_state.save()

            TaskState.objects.create(task=self, status=new_status)

            self.task_status = new_status
            self.updated_at = timezone.now()
            self.save()

            if user:
                TaskHistory.objects.create(
                    task=self,
                    editor=user,
                    field_name='task_status',
                    old_value=old_status_name,
                    new_value=new_status.status_name
                )
            
            logger.info(f"Task {self.id} status changed to {new_status.status_name}")
        except Exception as e:
            logger.error(f"Error changing task {self.id} status: {e}")
            raise

    def record_edit(self, editor, field_name, old_value, new_value):
        """Record field edits in history"""
        try:
            task_history = TaskHistory.objects.create(
                task=self,
                editor=editor,
                field_name=field_name,
                old_value=old_value,
                new_value=new_value
            )
            logger.debug(f"Task edit recorded: {task_history.id}")
            
            if field_name == 'task_status' and new_value:
                new_status = TaskStatus.objects.get(status_name=new_value)
                self.change_status(new_status.id, editor)
        except Exception as e:
            logger.error(f"Error recording task edit: {e}")

    def __str__(self):
        return f"{self.title} - {self.event}"


class TaskProgram(models.Model):
    """Scheduled task instances"""
    title = models.CharField(max_length=200)
    created_at = models.DateTimeField(auto_now_add=True)
    start_time = models.DateTimeField()
    end_time = models.DateTimeField()
    host = models.ForeignKey(User, on_delete=models.CASCADE, related_name='hosted_programs')
    task = models.ForeignKey('Task', on_delete=models.CASCADE)

    def clean(self):
        if self.start_time >= self.end_time:
            raise ValidationError('End time must be after start time')

    def __str__(self):
        return self.title

    class Meta:
        verbose_name = "Task Program"
        verbose_name_plural = "Task Programs"


class TaskSchedule(models.Model):
    """Recurring task scheduling model"""
    RECURRENCE_TYPES = [
        ('weekly', 'Weekly'),
        ('daily', 'Daily'),
        ('custom', 'Custom')
    ]

    task = models.ForeignKey('Task', on_delete=models.CASCADE)
    host = models.ForeignKey(User, on_delete=models.CASCADE)

    recurrence_type = models.CharField(max_length=20, choices=RECURRENCE_TYPES, default='weekly')

    # Week days
    monday = models.BooleanField(default=False)
    tuesday = models.BooleanField(default=False)
    wednesday = models.BooleanField(default=False)
    thursday = models.BooleanField(default=False)
    friday = models.BooleanField(default=False)
    saturday = models.BooleanField(default=False)
    sunday = models.BooleanField(default=False)

    # Timing
    start_time = models.TimeField()
    duration = models.DurationField(default='01:00:00')

    # Validity period
    start_date = models.DateField()
    end_date = models.DateField(null=True, blank=True)

    # Metadata
    created_at = models.DateTimeField(auto_now_add=True)
    updated_at = models.DateTimeField(auto_now=True)
    is_active = models.BooleanField(default=True)

    def get_next_occurrences(self, limit=10):
        """Generate next occurrences based on schedule"""
        from datetime import datetime, timedelta
        occurrences = []
        current_date = max(self.start_date, timezone.now().date())

        while len(occurrences) < limit:
            if self.end_date and current_date > self.end_date:
                break

            if self._should_schedule_on_date(current_date):
                start_datetime = datetime.combine(current_date, self.start_time)
                end_datetime = start_datetime + self.duration
                occurrences.append({
                    'date': current_date,
                    'start_time': start_datetime,
                    'end_time': end_datetime
                })

            current_date += timedelta(days=1)

        return occurrences

    def _should_schedule_on_date(self, date):
        """Determine if task should be scheduled on specific date"""
        if self.recurrence_type == 'daily':
            return True

        weekday = date.weekday()
        weekday_map = {
            0: self.monday,
            1: self.tuesday,
            2: self.wednesday,
            3: self.thursday,
            4: self.friday,
            5: self.saturday,
            6: self.sunday
        }

        return weekday_map.get(weekday, False)

    def get_selected_days_display(self):
        """Return readable representation of selected days"""
        days = []
        if self.monday: days.append('Mon')
        if self.tuesday: days.append('Tue')
        if self.wednesday: days.append('Wed')
        if self.thursday: days.append('Thu')
        if self.friday: days.append('Fri')
        if self.saturday: days.append('Sat')
        if self.sunday: days.append('Sun')

        return ", ".join(days) if days else "No days selected"

    def generate_occurrences(self, limit=10):
        """Generate list of future occurrences"""
        from datetime import datetime, timedelta
        occurrences = []
        current_date = max(self.start_date, timezone.now().date())

        while len(occurrences) < limit:
            if self.end_date and current_date > self.end_date:
                break

            if self._should_schedule_on_date(current_date):
                start_datetime = datetime.combine(current_date, self.start_time)
                end_datetime = start_datetime + self.duration
                occurrences.append({
                    'date': current_date,
                    'start_time': start_datetime,
                    'end_time': end_datetime
                })

            current_date += timedelta(days=1)

        return occurrences

    def create_task_programs(self, occurrences=None):
        """Create TaskProgram instances for specified occurrences"""
        if occurrences is None:
            occurrences = self.generate_occurrences()

        created_programs = []
        for occurrence in occurrences:
            program, created = TaskProgram.objects.get_or_create(
                task=self.task,
                host=self.host,
                start_time=occurrence['start_time'],
                defaults={
                    'title': f"{self.task.title} - {occurrence['start_time'].strftime('%d/%m/%Y %H:%M')}",
                    'end_time': occurrence['end_time'],
                }
            )

            if created:
                created_programs.append(program)

        return created_programs

    def get_next_occurrence(self):
        """Get the next future occurrence"""
        occurrences = self.generate_occurrences(limit=1)
        return occurrences[0] if occurrences else None

    def is_active_schedule(self):
        """Check if schedule is currently active"""
        if not self.is_active:
            return False
        if self.end_date and timezone.now().date() > self.end_date:
            return False
        return True

    def __str__(self):
        return f"{self.task.title} - {self.get_recurrence_type_display()} at {self.start_time}"

    class Meta:
        verbose_name = "Task Schedule"
        verbose_name_plural = "Task Schedules"
        ordering = ['start_time']


# ============================================================================
# GTD (GETTING THINGS DONE) MODELS
# ============================================================================

class InboxItem(models.Model):
    """GTD Inbox items with collaborative classification"""
    GTD_CATEGORIES = [
        ('actionable', 'Actionable'),
        ('non_actionable', 'Non Actionable'),
        ('pending', 'Pending Categorization')
    ]
    
    ACTION_TYPES = [
        ('do', 'Do'),
        ('delegate', 'Delegate'),
        ('defer', 'Defer'),
        ('project', 'Convert to Project'),
        ('delete', 'Delete'),
        ('archive', 'Archive for Reference'),
        ('incubate', 'Incubate (Someday/Maybe)'),
        ('waiting', 'Waiting For')
    ]
    
    PRIORITY_LEVELS = [
        ('high', 'High'),
        ('medium', 'Medium'),
        ('low', 'Low')
    ]
    
    ENERGY_LEVELS = [
        ('low', 'Low Energy'),
        ('medium', 'Medium Energy'),
        ('high', 'High Energy')
    ]
    
    TIME_PERIODS = [
        ('morning', 'Morning (6-12)'),
        ('afternoon', 'Afternoon (12-18)'),
        ('evening', 'Evening (18-24)'),
        ('night', 'Night (0-6)')
    ]

    title = models.CharField(max_length=200)
    description = models.TextField(blank=True)
    created_at = models.DateTimeField(auto_now_add=True)
    created_by = models.ForeignKey(User, on_delete=models.CASCADE)
    is_processed = models.BooleanField(default=False)
    processed_at = models.DateTimeField(null=True, blank=True)

    # Generic foreign key for processed items
    processed_to_content_type = models.ForeignKey(ContentType, null=True, blank=True, on_delete=models.SET_NULL)
    processed_to_object_id = models.PositiveIntegerField(null=True, blank=True)
    processed_to = GenericForeignKey('processed_to_content_type', 'processed_to_object_id')

    tags = models.ManyToManyField(Tag, blank=True)

    # GTD fields
    gtd_category = models.CharField(max_length=20, choices=GTD_CATEGORIES, default='pending', 
                                   help_text="Main GTD categorization")
    action_type = models.CharField(max_length=20, choices=ACTION_TYPES, blank=True, null=True,
                                  help_text="Specific action type")
    priority = models.CharField(max_length=10, choices=PRIORITY_LEVELS, default='medium',
                               help_text="Item priority")
    context = models.CharField(max_length=50, blank=True, 
                              help_text="Context where this can be done (e.g., @home, @work, @phone)")
    estimated_time = models.IntegerField(blank=True, null=True, 
                                        help_text="Estimated time in minutes")
    due_date = models.DateTimeField(blank=True, null=True, 
                                   help_text="Due date if applicable")
    energy_required = models.CharField(max_length=20, choices=ENERGY_LEVELS, default='medium',
                                      help_text="Required mental energy level")
    notes = models.TextField(blank=True, help_text="Additional processing notes")

    # Collaborative classification
    is_public = models.BooleanField(default=False, help_text="Can be viewed by other users?")
    assigned_to = models.ForeignKey(
        User,
        on_delete=models.SET_NULL,
        null=True,
        blank=True,
        related_name='assigned_inbox_items',
        help_text="User assigned to process this item"
    )
    authorized_users = models.ManyToManyField(
        User,
        through='InboxItemAuthorization',
        through_fields=('inbox_item', 'user'),
        related_name='authorized_inbox_items',
        blank=True,
        help_text="Users authorized to view and classify this item"
    )

    classification_votes = models.ManyToManyField(
        User,
        through='InboxItemClassification',
        through_fields=('inbox_item', 'user'),
        related_name='classified_inbox_items',
        blank=True,
        help_text="Users who have voted on classification"
    )

    # Activity tracking
    last_activity = models.DateTimeField(auto_now=True)
    view_count = models.PositiveIntegerField(default=0, help_text="Number of times viewed")

    # Additional GTD fields
    waiting_for = models.TextField(blank=True, help_text="What is being waited for? (e.g., client response)")
    waiting_for_date = models.DateTimeField(blank=True, null=True, help_text="Expected response date")
    next_review_date = models.DateTimeField(blank=True, null=True, help_text="Next review date")
    review_notes = models.TextField(blank=True, help_text="Previous review notes")

    # Analytics
    created_during = models.CharField(max_length=20, choices=TIME_PERIODS, blank=True,
                                     help_text="Creation time period for pattern analysis")
    user_context = models.JSONField(blank=True, null=True, help_text="Custom user context")

    def __str__(self):
        return f"{self.title} [{self.gtd_category}]"

    class Meta:
        ordering = ['-created_at']

    def get_classification_consensus(self):
        """Get classification consensus based on votes"""
        classifications = self.inboxitemclassification_set.values('gtd_category').annotate(
            count=models.Count('gtd_category')
        ).order_by('-count')

        if classifications:
            return classifications[0]['gtd_category']
        return self.gtd_category

    def get_action_type_consensus(self):
        """Get action type consensus based on votes"""
        action_types = self.inboxitemclassification_set.values('action_type').annotate(
            count=models.Count('action_type')
        ).order_by('-count')

        if action_types and action_types[0]['action_type']:
            return action_types[0]['action_type']
        return self.action_type

    def increment_views(self):
        """Increment view counter"""
        self.view_count += 1
        self.save(update_fields=['view_count', 'last_activity'])

    @property
    def is_linked_correctly(self):
        """Verify if item is correctly linked to processed object"""
        if not self.is_processed or not self.processed_to:
            return False
        
        try:
            obj = self.processed_to
            return hasattr(obj, 'title')
        except Exception as e:
            logger.warning(f"Error checking link for inbox item {self.id}: {e}")
            return False
    
    def get_processed_object_info(self):
        """Get information about the linked object"""
        if not self.is_processed or not self.processed_to:
            return None
        
        try:
            obj = self.processed_to
            return {
                'type': obj.__class__.__name__,
                'title': getattr(obj, 'title', 'Untitled'),
                'id': obj.id,
                'url': self._get_object_url(obj)
            }
        except Exception as e:
            logger.error(f"Error getting processed object info for inbox item {self.id}: {e}")
            return None
    
    def _get_object_url(self, obj):
        """Generate URL for linked object based on type"""
        from django.urls import reverse
        try:
            if isinstance(obj, Task):
                return reverse('tasks_with_id', args=[obj.id])
            elif isinstance(obj, Project):
                return reverse('project_detail', args=[obj.id])
            elif isinstance(obj, Event):
                return reverse('event_detail', args=[obj.id])
        except Exception as e:
            logger.warning(f"Error generating URL for object {obj.id}: {e}")
        return None
    
    def fix_link(self, new_object):
        """Fix the link to a new object"""
        try:
            from django.contrib.contenttypes.models import ContentType
            
            self.processed_to_content_type = ContentType.objects.get_for_model(type(new_object))
            self.processed_to_object_id = new_object.id
            self.save()
            logger.info(f"Fixed link for inbox item {self.id} to {new_object.__class__.__name__} {new_object.id}")
            return True
        except Exception as e:
            logger.error(f"Error fixing link for inbox item {self.id}: {e}")
            return False

    def assign_to_available_user(self):
        """Automatically assign item to available user based on workload and specialization"""
        try:
            from django.contrib.auth.models import User
            from django.db.models import Count

            available_users = User.objects.filter(
                is_active=True,
                profile__isnull=False
            ).exclude(
                profile__role__in=['SU']
            )

            if not available_users.exists():
                logger.warning("No available users found for assignment")
                return False

            # Calculate current workload
            user_workloads = {}
            for user in available_users:
                assigned_count = InboxItem.objects.filter(
                    assigned_to=user,
                    is_processed=False
                ).count()

                specialization_bonus = 0
                if hasattr(user, 'profile') and user.profile:
                    if 'CX' in str(user.profile.role or ''):
                        specialization_bonus = -2
                    elif 'FTE' in str(user.profile.role or ''):
                        specialization_bonus = -1

                user_workloads[user.id] = {
                    'user': user,
                    'workload': assigned_count + specialization_bonus,
                    'role': getattr(user.profile, 'role', None) if hasattr(user, 'profile') else None
                }

            sorted_users = sorted(user_workloads.values(), key=lambda x: x['workload'])
            best_user = sorted_users[0]['user']
            
            self.assigned_to = best_user
            self.save(update_fields=['assigned_to'])

            InboxItemHistory.objects.create(
                inbox_item=self,
                user=best_user,
                action='auto_assigned',
                new_values={
                    'assigned_to': best_user.username,
                    'assignment_method': 'automatic'
                }
            )
            
            logger.info(f"Inbox item {self.id} automatically assigned to {best_user.username}")
            return True
        except Exception as e:
            logger.error(f"Error in auto-assignment for inbox item {self.id}: {e}")
            return False


class InboxItemAuthorization(models.Model):
    """Authorization levels for inbox items"""
    PERMISSION_LEVELS = [
        ('view', 'View Only'),
        ('classify', 'View and Classify'),
        ('edit', 'View, Classify and Edit'),
        ('admin', 'Full Admin')
    ]

    inbox_item = models.ForeignKey('InboxItem', on_delete=models.CASCADE)
    user = models.ForeignKey(User, on_delete=models.CASCADE)
    granted_by = models.ForeignKey(User, on_delete=models.CASCADE, related_name='granted_authorizations')
    granted_at = models.DateTimeField(auto_now_add=True)
    permission_level = models.CharField(max_length=20, choices=PERMISSION_LEVELS, default='classify')

    def __str__(self):
        return f"{self.user.username} -> {self.inbox_item.title} ({self.permission_level})"

    class Meta:
        unique_together = ['inbox_item', 'user']


