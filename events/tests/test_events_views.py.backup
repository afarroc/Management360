# TESTS DE EDICIÓN DE EVENTOS
# ============================================================================

class EventEditViewTests(BaseEventTestCase):
    """Tests para la edición de eventos"""
    
    def setUp(self):
        super().setUp()
        self.edit_data = {
            'title': 'Título Actualizado',
            'description': 'Descripción actualizada',
            'venue': self.event1.venue,
            'event_category': self.event1.event_category,
            'max_attendees': self.event1.max_attendees,
            'ticket_price': self.event1.ticket_price,
            'event_status': self.event1.event_status.id,
            'assigned_to': self.event1.assigned_to.id,
        }
    
    def test_edit_form_display(self):
        """El formulario de edición se muestra correctamente"""
        response = self.client.get(reverse('event_edit', args=[self.event1.id]))
        
        self.assertEqual(response.status_code, 200)
        self.assertTemplateUsed(response, 'events/event_edit.html')
        self.assertEqual(response.context['event'].id, self.event1.id)
    
    def test_edit_event_valid_data(self):
        """Edición con datos válidos"""
        response = self.client.post(
            reverse('event_edit', args=[self.event1.id]), 
            self.edit_data
        )
        
        self.assertEqual(response.status_code, 302)
        self.assertRedirects(response, reverse('event_panel'))
        
        self.event1.refresh_from_db()
        self.assertEqual(self.event1.title, 'Título Actualizado')
    
    def test_edit_event_status_change(self):
        """Cambio de estado durante edición"""
        data = self.edit_data.copy()
        data['event_status'] = self.status_in_progress.id
        
        response = self.client.post(
            reverse('event_edit', args=[self.event1.id]), 
            data
        )
        
        self.assertEqual(response.status_code, 302)
        
        self.event1.refresh_from_db()
        self.assertEqual(self.event1.event_status, self.status_in_progress)
    
    def test_unauthorized_user_cannot_edit(self):
        """Usuario no autorizado no puede editar"""
        self.client.login(username='unauthorized', password='unauthpass123')
        
        response = self.client.get(reverse('event_edit', args=[self.event1.id]))
        
        # Debe redirigir con mensaje de error
        self.assertEqual(response.status_code, 302)
        self.assertRedirects(response, reverse('event_panel'))


# ============================================================================
# TESTS DE CAMBIO DE ESTADO
# ============================================================================

class EventStatusChangeTests(BaseEventTestCase):
    """Tests para cambio de estado de eventos"""
    
    def test_status_change_post(self):
        """Cambio de estado vía POST"""
        response = self.client.post(
            reverse('event_status_change', args=[self.event1.id]),
            {'new_status_id': self.status_in_progress.id}
        )
        
        self.assertEqual(response.status_code, 302)
        self.assertRedirects(response, reverse('events'))
        
        self.event1.refresh_from_db()
        self.assertEqual(self.event1.event_status, self.status_in_progress)
    
    def test_status_change_invalid_method(self):
        """GET no permite cambio de estado"""
        response = self.client.get(
            reverse('event_status_change', args=[self.event1.id])
        )
        
        # Debe ser 405 (Method Not Allowed) o 302 (redirección)
        self.assertIn(response.status_code, [302, 405])
    
    def test_unauthorized_user_cannot_change_status(self):
        """Usuario no autorizado no puede cambiar estado"""
        self.client.login(username='unauthorized', password='unauthpass123')
        
        response = self.client.post(
            reverse('event_status_change', args=[self.event1.id]),
            {'new_status_id': self.status_in_progress.id}
        )
        
        self.assertIn(response.status_code, [302, 403])


