# events/tests/test_events_views.py
"""
Tests unitarios para las vistas de eventos.
Versión CORREGIDA - con autenticación funcionando.
"""

from django.test import TestCase, Client
from django.urls import reverse
from django.contrib.auth.models import User
from django.utils import timezone
from django.contrib.messages import get_messages
from django.db import IntegrityError
from unittest.mock import patch
from datetime import timedelta

from events.models import (
    Event, EventState, EventAttendee, Status, 
    Project, Task, ProjectStatus, TaskStatus
)


class BaseEventTestCase(TestCase):
    """Clase base con configuración común para todos los tests"""
    
    @classmethod
    def setUpTestData(cls):
        """Configuración inicial compartida - SOLO UNA VEZ"""
        # Usuarios - IMPORTANTE: username es el campo de autenticación
        cls.superuser = User.objects.create_superuser(
            username='admin', 
            email='admin@test.com', 
            password='adminpass123'
        )
        cls.host_user = User.objects.create_user(
            username='host', 
            email='host@test.com', 
            password='hostpass123'
        )
        cls.assigned_user = User.objects.create_user(
            username='assigned', 
            email='assigned@test.com', 
            password='assignedpass123'
        )
        cls.attendee_user = User.objects.create_user(
            username='attendee', 
            email='attendee@test.com', 
            password='attendeepass123'
        )
        cls.unauthorized_user = User.objects.create_user(
            username='unauthorized', 
            email='unauth@test.com', 
            password='unauthpass123'
        )
        
        # Estados
        cls.status_created = Status.objects.create(status_name='Created', active=True)
        cls.status_in_progress = Status.objects.create(status_name='In Progress', active=True)
        cls.status_completed = Status.objects.create(status_name='Completed', active=True)
        
        # Eventos base
        cls.event1 = Event.objects.create(
            title='Evento 1',
            description='Descripción 1',
            event_status=cls.status_created,
            venue='Lugar 1',
            host=cls.host_user,
            assigned_to=cls.assigned_user
        )
        
        cls.event2 = Event.objects.create(
            title='Evento 2',
            description='Descripción 2',
            event_status=cls.status_in_progress,
            venue='Lugar 2',
            host=cls.host_user,
            assigned_to=cls.assigned_user
        )
        
        cls.event3 = Event.objects.create(
            title='Evento 3',
            description='Descripción 3',
            event_status=cls.status_completed,
            venue='Lugar 3',
            host=cls.host_user,
            assigned_to=cls.assigned_user
        )
        
        # Asistente
        EventAttendee.objects.create(user=cls.attendee_user, event=cls.event1)
        
        # Proyecto y tarea relacionados
        cls.project_status = ProjectStatus.objects.create(status_name='Active')
        cls.task_status = TaskStatus.objects.create(status_name='Pending')
        
        cls.project1 = Project.objects.create(
            title='Proyecto relacionado',
            event=cls.event1,
            project_status=cls.project_status,
            host=cls.host_user,
            assigned_to=cls.assigned_user
        )
        
        cls.task1 = Task.objects.create(
            title='Tarea relacionada',
            event=cls.event1,
            task_status=cls.task_status,
            assigned_to=cls.assigned_user,
            host=cls.host_user
        )

    def setUp(self):
        """Configuración antes de cada test - login con USERNAME"""
        self.client = Client()
        # IMPORTANTE: login con username, NO con email
        self.client.login(username='host', password='hostpass123')
        
    def assertMessageContains(self, response, text):
        """Verificar que existe un mensaje con el texto dado"""
        messages = list(get_messages(response.wsgi_request))
        self.assertTrue(any(text.lower() in str(m).lower() for m in messages))


# ============================================================================
# TESTS DE AUTENTICACIÓN Y ACCESO
# ============================================================================

class AuthenticationTests(TestCase):
    """Tests de autenticación y permisos básicos"""
    
    @classmethod
    def setUpTestData(cls):
        cls.user = User.objects.create_user(username='testuser', password='testpass123')
    
    def test_views_require_login(self):
        """Todas las vistas principales requieren login"""
        protected_urls = [
            ('events', None),
            ('event_detail', {'event_id': 1}),
            ('event_create', None),
            ('event_edit', {'event_id': 1}),
            ('event_delete', {'event_id': 1}),
            ('event_panel', None),
        ]
        
        for url_name, kwargs in protected_urls:
            with self.subTest(url=url_name):
                url = reverse(url_name, kwargs=kwargs) if kwargs else reverse(url_name)
                response = self.client.get(url)
                self.assertEqual(response.status_code, 302)
                self.assertIn('/accounts/login/', response.url)
    
    def test_authenticated_user_can_access(self):
        """Usuario autenticado puede acceder a vistas principales"""
        self.client.login(username='testuser', password='testpass123')
        
        accessible_urls = [
            ('events', None, 200),
            ('event_detail', {'event_id': 1}, 404),  # 404 porque el evento no existe
            ('event_create', None, 200),
            ('event_edit', {'event_id': 1}, 404),    # 404 porque el evento no existe
            ('event_panel', None, 200),
            ('event_export', None, 200),
        ]
        
        for url_name, kwargs, expected_status in accessible_urls:
            with self.subTest(url=url_name):
                url = reverse(url_name, kwargs=kwargs) if kwargs else reverse(url_name)
                response = self.client.get(url)
                self.assertEqual(response.status_code, expected_status)


