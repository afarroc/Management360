class EventAssignmentTests(BaseEventTestCase):
    """Tests para asignación de proyectos/tareas a eventos"""
    
    def setUp(self):
        super().setUp()
        self.new_task = Task.objects.create(
            title='Tarea para asignar',
            description='Descripción',
            task_status=self.task_status,
            assigned_to=self.assigned_user,
            host=self.host_user
        )
        
        self.new_project = Project.objects.create(
            title='Proyecto para asignar',
            description='Descripción',
            project_status=self.project_status,
            host=self.host_user,
            assigned_to=self.assigned_user
        )
    
    def test_assign_task_to_event(self):
        """Asignar tarea a evento"""
        response = self.client.post(
            reverse('event_assign', args=[self.event1.id]),
            {'assign_task_id': self.new_task.id}
        )
        
        self.assertEqual(response.status_code, 302)
        
        self.new_task.refresh_from_db()
        self.assertEqual(self.new_task.event_id, self.event1.id)
    
    def test_assign_project_to_event(self):
        """Asignar proyecto a evento"""
        response = self.client.post(
            reverse('event_assign', args=[self.event1.id]),
            {'assign_project_id': self.new_project.id}
        )
        
        self.assertEqual(response.status_code, 302)
        
        self.new_project.refresh_from_db()
        self.assertEqual(self.new_project.event_id, self.event1.id)


# ============================================================================
# TESTS DE SEGURIDAD
# ============================================================================

class SecurityTests(BaseEventTestCase):
    """Tests de seguridad"""
    
    def test_sql_injection_protection(self):
        """Protección contra inyección SQL"""
        malicious_input = "2024-01-01'; DROP TABLE events_event; --"
        
        response = self.client.post(reverse('events'), {'date': malicious_input})
        
        # La vista maneja el input sin error
        self.assertEqual(response.status_code, 200)
        # La tabla sigue existiendo
        self.assertTrue(Event.objects.exists())
    
    def test_xss_protection(self):
        """Protección contra XSS"""
        malicious_title = '<script>alert("XSS")</script>'
        
        event_data = {
            'title': malicious_title,
            'description': 'Descripción',
            'venue': 'Lugar',
            'event_category': 'Test',
            'max_attendees': 30,
            'ticket_price': '50.00',
            'event_status': self.status_created.id,
            'assigned_to': self.assigned_user.id,
        }
        
        response = self.client.post(reverse('event_create'), event_data)
        self.assertEqual(response.status_code, 302)
        
        new_event = Event.objects.get(title=malicious_title)
        
        # Verificar que el HTML está escapado en la respuesta
        detail_response = self.client.get(reverse('event_detail', args=[new_event.id]))
        content = detail_response.content.decode('utf-8')
        self.assertNotIn('<script>', content)
    
    def test_idor_protection(self):
        """Protección contra IDOR"""
        self.client.login(username='attendee', password='attendeepass123')
        
        # Intentar acceder a evento que no le pertenece
        response = self.client.get(reverse('event_detail', args=[self.event2.id]))
        
        self.assertEqual(response.status_code, 302)
        self.assertRedirects(response, reverse('events'))


# ============================================================================
# TESTS DE CASOS EDGE
# ============================================================================

class EdgeCasesTests(BaseEventTestCase):
    """Tests para casos edge"""
    
    def test_event_without_venue(self):
        """Evento sin lugar"""
        # Usar el cliente autenticado de BaseEventTestCase
        response = self.client.get(reverse('event_detail', args=[self.event1.id]))
        self.assertEqual(response.status_code, 200)
    
    def test_event_with_zero_attendees(self):
        """Evento con max_attendees=0"""
        response = self.client.get(reverse('event_detail', args=[self.event2.id]))
        self.assertEqual(response.status_code, 200)
    
    def test_event_with_negative_price(self):
        """Evento con precio negativo"""
        event_data = {
            'title': 'Evento Precio Negativo',
            'venue': 'Lugar',
            'event_category': 'Test',
            'max_attendees': 30,
            'ticket_price': '-50.00',
            'event_status': self.status_created.id,
            'assigned_to': self.assigned_user.id,
        }
        
        response = self.client.post(reverse('event_create'), event_data)
        # Puede aceptar (302) o rechazar (200) - ambos son válidos
        self.assertIn(response.status_code, [200, 302])


# ============================================================================
# TESTS DE URLs
# ============================================================================

class URLTests(TestCase):
    """Tests para resolución de URLs"""
    
    def test_url_names_resolve(self):
        """Los nombres de URL resuelven correctamente"""
        url_names = [
            'events', 'event_create', 'event_panel', 'event_export',
            'event_bulk_action', 'event_assign_no_id', 'event_history_no_id'
        ]
        
        for name in url_names:
            with self.subTest(url_name=name):
                try:
                    url = reverse(name)
                    self.assertIsNotNone(url)
                except Exception as e:
                    self.fail(f"URL {name} falló: {e}")
    
    def test_urls_with_parameters_resolve(self):
        """URLs con parámetros resuelven correctamente"""
        url_configs = [
            ('event_detail', {'event_id': 1}),
            ('event_edit', {'event_id': 1}),
            ('event_delete', {'event_id': 1}),
            ('event_status_change', {'event_id': 1}),
            ('event_assign', {'event_id': 1}),
            ('event_history', {'event_id': 1}),
            ('event_panel_with_id', {'event_id': 1}),
            ('assign_attendee_to_event', {'event_id': 1, 'user_id': 1}),
        ]
        
        for name, kwargs in url_configs:
            with self.subTest(url_name=name):
                try:
                    url = reverse(name, kwargs=kwargs)
                    self.assertIsNotNone(url)
                except Exception as e:
                    self.fail(f"URL {name} con args {kwargs} falló: {e}")