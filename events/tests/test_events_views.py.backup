# TESTS DE ELIMINACIÓN
# ============================================================================

class EventDeleteTests(BaseEventTestCase):
    """Tests para eliminación de eventos"""
    
    def test_superuser_can_delete(self):
        """Superusuario puede eliminar evento"""
        self.client.login(username='admin', password='adminpass123')
        
        event_count = Event.objects.count()
        event_id = self.event3.id
        
        response = self.client.post(reverse('event_delete', args=[event_id]))
        
        self.assertEqual(response.status_code, 302)
        self.assertRedirects(response, reverse('event_panel'))
        self.assertEqual(Event.objects.count(), event_count - 1)
    
    def test_regular_user_cannot_delete(self):
        """Usuario normal no puede eliminar"""
        event_count = Event.objects.count()
        event_id = self.event1.id
        
        response = self.client.post(reverse('event_delete', args=[event_id]))
        
        self.assertEqual(response.status_code, 302)
        self.assertEqual(Event.objects.count(), event_count)  # Sin cambios
    
    def test_delete_invalid_method(self):
        """GET no permite eliminar"""
        self.client.login(username='admin', password='adminpass123')
        
        response = self.client.get(reverse('event_delete', args=[self.event1.id]))
        self.assertEqual(response.status_code, 302)  # Redirige


# ============================================================================
# TESTS DE ACCIONES MASIVAS
# ============================================================================

class EventBulkActionTests(BaseEventTestCase):
    """Tests para acciones masivas"""
    
    def test_bulk_activate(self):
        """Activación masiva"""
        self.event1.event_status = self.status_created
        self.event1.save()
        
        response = self.client.post(
            reverse('event_bulk_action'),
            {'action': 'activate', 'selected_items': [self.event1.id]}
        )
        
        self.assertEqual(response.status_code, 302)
        
        self.event1.refresh_from_db()
        self.assertEqual(self.event1.event_status, self.status_in_progress)
    
    def test_bulk_complete(self):
        """Completado masivo"""
        response = self.client.post(
            reverse('event_bulk_action'),
            {'action': 'complete', 'selected_items': [self.event1.id, self.event2.id]}
        )
        
        self.assertEqual(response.status_code, 302)
        
        self.event1.refresh_from_db()
        self.event2.refresh_from_db()
        self.assertEqual(self.event1.event_status, self.status_completed)
        self.assertEqual(self.event2.event_status, self.status_completed)
    
    def test_bulk_delete_superuser(self):
        """Eliminación masiva por superusuario"""
        self.client.login(username='admin', password='adminpass123')
        
        event_count = Event.objects.count()
        
        response = self.client.post(
            reverse('event_bulk_action'),
            {'action': 'delete', 'selected_items': [self.event1.id, self.event2.id]}
        )
        
        self.assertEqual(response.status_code, 302)
        self.assertRedirects(response, reverse('event_panel'))
        self.assertEqual(Event.objects.count(), event_count - 2)
    
    def test_bulk_action_no_selection(self):
        """Acción masiva sin selección"""
        response = self.client.post(
            reverse('event_bulk_action'),
            {'action': 'activate'}
        )
        
        self.assertEqual(response.status_code, 302)
        self.assertRedirects(response, reverse('event_panel'))


