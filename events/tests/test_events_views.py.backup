class EventHistoryTests(BaseEventTestCase):
    """Tests para historial de eventos"""
    
    def setUp(self):
        super().setUp()
        # Crear estados históricos
        for i in range(3):
            EventState.objects.create(
                event=self.event1,
                status=self.status_created,
                start_time=timezone.now() - timedelta(days=i)
            )
    
    def test_history_with_event_id(self):
        """Historial de evento específico"""
        response = self.client.get(reverse('event_history', args=[self.event1.id]))
        
        self.assertEqual(response.status_code, 200)
        self.assertTemplateUsed(response, 'events/event_history.html')
    
    def test_history_without_id(self):
        """Historial general"""
        response = self.client.get(reverse('event_history_no_id'))
        
        self.assertEqual(response.status_code, 200)
        self.assertIn('page_obj', response.context)


