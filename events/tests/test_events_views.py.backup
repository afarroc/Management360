class EventExportTests(BaseEventTestCase):
    """Tests para exportación de eventos"""
    
    def test_export_csv(self):
        """Exportación a CSV"""
        response = self.client.get(reverse('event_export'))
        
        self.assertEqual(response.status_code, 200)
        self.assertEqual(response['Content-Type'], 'text/csv')
        
    def test_superuser_exports_all(self):
        """Superusuario exporta todos los eventos"""
        self.client.login(username='admin', password='adminpass123')
        
        response = self.client.get(reverse('event_export'))
        content = response.content.decode('utf-8')
        lines = content.strip().split('\n')
        
        # Header + número de eventos
        self.assertEqual(len(lines) - 1, Event.objects.count())


