class EventsListViewTests(BaseEventTestCase):
    """Tests para la vista principal de listado de eventos"""
    
    def test_events_list_context(self):
        """La vista events tiene el contexto correcto"""
        response = self.client.get(reverse('events'))
        
        self.assertEqual(response.status_code, 200)
        self.assertTemplateUsed(response, 'events/events.html')
        self.assertIn('events', response.context)
        self.assertIn('event_statuses', response.context)
    
    def test_events_list_filters(self):
        """Los filtros funcionan correctamente"""
        response = self.client.post(reverse('events'), {
            'completed': 'true',
            'status': self.status_in_progress.id,
            'date': timezone.now().date().isoformat()
        })
        
        self.assertEqual(response.status_code, 200)


# ============================================================================
# TESTS DE DETALLE DE EVENTO
# ============================================================================

class EventDetailViewTests(BaseEventTestCase):
    """Tests para la vista de detalle de evento"""
    
    def test_host_can_view_detail(self):
        """El host puede ver el detalle"""
        response = self.client.get(reverse('event_detail', args=[self.event1.id]))
        self.assertEqual(response.status_code, 200)
        self.assertEqual(response.context['event'].id, self.event1.id)
    
    def test_assigned_user_can_view_detail(self):
        """El usuario asignado puede ver el detalle"""
        self.client.login(username='assigned', password='assignedpass123')
        response = self.client.get(reverse('event_detail', args=[self.event1.id]))
        self.assertEqual(response.status_code, 200)
    
    def test_attendee_can_view_detail(self):
        """El asistente puede ver el detalle"""
        self.client.login(username='attendee', password='attendeepass123')
        response = self.client.get(reverse('event_detail', args=[self.event1.id]))
        self.assertEqual(response.status_code, 200)
    
    def test_unauthorized_user_cannot_view_detail(self):
        """Usuario no autorizado no puede ver el detalle"""
        self.client.login(username='unauthorized', password='unauthpass123')
        response = self.client.get(reverse('event_detail', args=[self.event1.id]))
        
        # Debe redirigir con mensaje de error
        self.assertEqual(response.status_code, 302)
        self.assertRedirects(response, reverse('events'))
    
    def test_nonexistent_event_returns_404(self):
        """Evento inexistente retorna 404"""
        response = self.client.get(reverse('event_detail', args=[9999]))
        self.assertEqual(response.status_code, 404)
    
    def test_detail_shows_related_objects(self):
        """El detalle muestra proyectos y tareas relacionados"""
        response = self.client.get(reverse('event_detail', args=[self.event1.id]))
        
        # Verificar que los contextos existen (pueden ser None si no hay objetos)
        self.assertIn('projects', response.context)
        self.assertIn('tasks', response.context)


# ============================================================================
# TESTS DE CREACIÓN DE EVENTOS
# ============================================================================

class EventCreateViewTests(BaseEventTestCase):
    """Tests para la creación de eventos"""
    
    def setUp(self):
        super().setUp()
        self.valid_event_data = {
            'title': 'Nuevo Evento',
            'description': 'Descripción',
            'venue': 'Lugar de test',
            'event_category': 'Test',
            'max_attendees': 30,
            'ticket_price': '50.00',
            'event_status': self.status_created.id,
            'assigned_to': self.assigned_user.id,
            'attendees': [self.attendee_user.id]
        }
    
    def test_create_form_display(self):
        """El formulario de creación se muestra correctamente"""
        response = self.client.get(reverse('event_create'))
        self.assertEqual(response.status_code, 200)
        self.assertTemplateUsed(response, 'events/event_create.html')
    
    def test_create_event_valid_data(self):
        """Creación con datos válidos"""
        response = self.client.post(reverse('event_create'), self.valid_event_data)
        
        self.assertEqual(response.status_code, 302)  # Redirección después de crear
        self.assertRedirects(response, reverse('events'))
        
        new_event = Event.objects.filter(title='Nuevo Evento').first()
        self.assertIsNotNone(new_event)
        self.assertEqual(new_event.host, self.host_user)
    
    def test_create_event_invalid_data(self):
        """Creación con datos inválidos"""
        invalid_data = {
            'description': 'Sin título',
            'venue': 'Lugar',
        }
        
        response = self.client.post(reverse('event_create'), invalid_data)
        
        # Debe volver al formulario con errores (status 200)
        self.assertEqual(response.status_code, 200)
        self.assertTrue(response.context['form'].errors)
    
    def test_superuser_can_set_initial_status(self):
        """Superusuario puede elegir estado inicial"""
        self.client.login(username='admin', password='adminpass123')
        
        data = self.valid_event_data.copy()
        data['event_status'] = self.status_in_progress.id
        data['title'] = 'Evento Superuser'
        
        response = self.client.post(reverse('event_create'), data)
        self.assertEqual(response.status_code, 302)
        self.assertRedirects(response, reverse('events'))
        
        new_event = Event.objects.get(title='Evento Superuser')
        self.assertEqual(new_event.event_status, self.status_in_progress)


